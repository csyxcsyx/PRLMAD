{
  "name": "prlmad-frontend",
  "private": true,
  "version": "0.3.0",
  "description": "Reproducible local frontend assets for PRLMAD",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm run build:css && pnpm run build:vendor",
    "build:css": "tailwindcss -c tailwind.config.cjs -i frontend/styles.css -o static/css/app.css --minify",
    "build:vendor": "node scripts/copy-vendor.mjs",
    "check:assets": "node scripts/check-assets.mjs"
  },
  "dependencies": {
    "@fontsource-variable/cormorant-garamond": "5.2.6",
    "@fontsource-variable/inter": "5.2.6",
    "alpinejs": "3.14.8",
    "dompurify": "3.2.6",
    "echarts": "5.6.0",
    "marked": "15.0.12",
    "mermaid": "11.6.0"
  },
  "devDependencies": {
    "tailwindcss": "3.4.17"
  }
}
